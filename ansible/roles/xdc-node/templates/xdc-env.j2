# XDC Node Environment Configuration
# Generated by Ansible
# Do not edit manually - changes will be overwritten

# Node Identity
NODE_TYPE={{ node_role | default('full') }}
NETWORK={{ xdc_network | default('mainnet') }}
CLIENT={{ client | default('XDPoSChain') }}

# Data Directories
DATA_DIR={{ xdc_data_dir | default('/root/XDC-Node') }}
LOGS_DIR={{ xdc_logs_dir | default('/var/log/xdc') }}

# Network Ports
RPC_PORT={{ rpc_port | default(8545) }}
WS_PORT={{ ws_port | default(8546) }}
P2P_PORT={{ p2p_port | default(30303) }}
METRICS_PORT={{ metrics_port | default(6060) }}

# RPC Configuration
RPC_API={{ rpc_api | default('eth,net,web3,txpool') }}
WS_API={{ ws_api | default('eth,net,web3') }}
ENABLE_RPC={{ 'true' if enable_rpc | default(true) | bool else 'false' }}
ENABLE_WS={{ 'true' if enable_ws | default(false) | bool else 'false' }}

# Sync and Pruning
SYNC_MODE={{ sync_mode | default('snap') }}
PRUNING_MODE={{ pruning_mode | default('default') }}

# Performance
CACHE_SIZE={{ cache_size | default(4096) }}
MAX_PEERS={{ max_peers | default(25) }}

# Metrics
ENABLE_METRICS={{ 'true' if enable_metrics | default(true) | bool else 'false' }}

# Bootnodes (if custom)
{% if bootnodes | default('') | length > 0 %}
BOOTNODES={{ bootnodes }}
{% endif %}

# Gas Configuration
{% if gas_target | default('') | length > 0 %}
GAS_TARGET={{ gas_target }}
{% endif %}
{% if gas_limit | default('') | length > 0 %}
GAS_LIMIT={{ gas_limit }}
{% endif %}
