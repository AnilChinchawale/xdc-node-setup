#!/bin/bash
# XDC Node Backup Script
# Generated by Ansible - {{ ansible_date_time.iso8601 }}

set -euo pipefail

# Configuration
BACKUP_DIR="{{ backup_dir }}"
DATA_DIR="{{ xdc_data_dir | default('/root/XDC-Node') }}"
RETENTION_DAYS="{{ backup_retention_days }}"
ENCRYPTION_KEY="{{ backup_encryption_key }}"
S3_BUCKET="{{ backup_s3_bucket }}"
S3_REGION="{{ backup_s3_region }}"
S3_PATH="{{ backup_s3_path }}"

# Logging
LOG_FILE="{{ backup_log_dir }}/backup-$(date +%Y%m%d-%H%M%S).log"
exec 1> >(tee -a "$LOG_FILE")
exec 2>&1

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

error() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] ERROR: $1" >&2
    exit 1
}

# Create backup directory
mkdir -p "$BACKUP_DIR"

# Check if another backup is running
LOCK_FILE="{{ backup_lock_file }}"
if [[ -f "$LOCK_FILE" ]]; then
    PID=$(cat "$LOCK_FILE")
    if ps -p "$PID" > /dev/null 2>&1; then
        error "Another backup is already running (PID: $PID)"
    else
        log "Removing stale lock file"
        rm -f "$LOCK_FILE"
    fi
fi

echo $$ > "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

# Generate backup filename
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BACKUP_FILE="xdc-backup-${TIMESTAMP}.tar.gz"
BACKUP_PATH="$BACKUP_DIR/$BACKUP_FILE"

log "Starting backup: $BACKUP_FILE"

# Run pre-backup script if exists
{% if backup_pre_script | length > 0 %}
if [[ -x "{{ backup_pre_script }}" ]]; then
    log "Running pre-backup script"
    "{{ backup_pre_script }}" || error "Pre-backup script failed"
fi
{% endif %}

# Create backup
log "Creating archive..."
tar czf "$BACKUP_PATH" \
{% for pattern in backup_exclude_patterns %}
    --exclude='{{ pattern }}' \
{% endfor %}
    -C "$(dirname "$DATA_DIR")" \
    "$(basename "$DATA_DIR")"

BACKUP_SIZE=$(du -h "$BACKUP_PATH" | cut -f1)
log "Backup created: $BACKUP_PATH ($BACKUP_SIZE)"

# Encrypt if key provided
{% if backup_encryption | bool and backup_encryption_key | length > 0 %}
log "Encrypting backup..."
gpg --symmetric --cipher-algo AES256 \
    --output "${BACKUP_PATH}.gpg" \
    --passphrase "$ENCRYPTION_KEY" \
    --batch --yes \
    "$BACKUP_PATH"
rm -f "$BACKUP_PATH"
BACKUP_PATH="${BACKUP_PATH}.gpg"
BACKUP_FILE="${BACKUP_FILE}.gpg"
log "Encryption complete"
{% endif %}

# Upload to S3 if enabled
{% if backup_s3_enabled | bool and backup_s3_bucket | length > 0 %}
log "Uploading to S3..."
aws s3 cp "$BACKUP_PATH" "s3://${S3_BUCKET}/${S3_PATH}/" \
    --storage-class {{ backup_s3_storage_class }} \
    --region "$S3_REGION"
log "S3 upload complete"
{% endif %}

# Run post-backup script if exists
{% if backup_post_script | length > 0 %}
if [[ -x "{{ backup_post_script }}" ]]; then
    log "Running post-backup script"
    "{{ backup_post_script }}" "$BACKUP_PATH" || log "Warning: Post-backup script failed"
fi
{% endif %}

# Clean up old backups
log "Cleaning up old backups..."
find "$BACKUP_DIR" -name "xdc-backup-*.tar.gz*" -mtime +"$RETENTION_DAYS" -delete

# Clean up old S3 backups
{% if backup_s3_enabled | bool and backup_s3_bucket | length > 0 %}
log "Cleaning up old S3 backups..."
aws s3 ls "s3://${S3_BUCKET}/${S3_PATH}/" | \
    awk '{print $4}' | \
    while read file; do
        # Parse date from filename and delete if older than retention
        file_date=$(echo "$file" | grep -oP '\d{8}' || true)
        if [[ -n "$file_date" ]]; then
            file_epoch=$(date -d "${file_date:0:4}-${file_date:4:2}-${file_date:6:2}" +%s 2>/dev/null || echo 0)
            cutoff_epoch=$(date -d "-$RETENTION_DAYS days" +%s)
            if [[ $file_epoch -lt $cutoff_epoch ]]; then
                aws s3 rm "s3://${S3_BUCKET}/${S3_PATH}/$file"
            fi
        fi
    done
{% endif %}

log "Backup completed successfully: $BACKUP_FILE ($BACKUP_SIZE)"
