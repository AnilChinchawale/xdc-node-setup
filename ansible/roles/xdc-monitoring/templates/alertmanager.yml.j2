global:
  smtp_smarthost: '{{ alert_smtp_host }}:{{ alert_smtp_port }}'
  smtp_from: '{{ alert_email_from }}'
  smtp_auth_username: '{{ alert_email_from }}'
  smtp_auth_password: '{{ vault_smtp_password | default("") }}'
  
  slack_api_url: '{{ alert_slack_webhook }}'

templates:
- '/etc/alertmanager/*.tmpl'

route:
  group_by: ['alertname', 'cluster', 'service']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  receiver: 'default'
  routes:
    - match:
        severity: critical
      receiver: 'critical'
      continue: true
    - match:
        severity: warning
      receiver: 'warning'

inhibit_rules:
  - source_match:
      severity: 'critical'
    target_match:
      severity: 'warning'
    equal: ['alertname', 'cluster', 'service']

receivers:
  - name: 'default'
    {% if alert_email_to | length > 0 %}
    email_configs:
      - to: '{{ alert_email_to }}'
        subject: 'XDC Node Alert: {{ '{{' }} .GroupLabels.alertname {{ '}}' }}'
        body: |
          {{ '{{' }} range .Alerts {{ '}}' }}
          Alert: {{ '{{' }} .Annotations.summary {{ '}}' }}
          Description: {{ '{{' }} .Annotations.description {{ '}}' }}
          {{ '{{' }} end {{ '}}' }}
    {% endif %}
    {% if alert_slack_webhook | length > 0 %}
    slack_configs:
      - channel: '#alerts'
        title: 'XDC Node Alert'
        text: '{{ '{{' }} .GroupLabels.alertname {{ '}}' }}'
    {% endif %}

  - name: 'critical'
    {% if alert_email_to | length > 0 %}
    email_configs:
      - to: '{{ alert_email_to }}'
        subject: 'CRITICAL: XDC Node Alert'
        priority: high
    {% endif %}
    {% if alert_slack_webhook | length > 0 %}
    slack_configs:
      - channel: '#critical-alerts'
        title: 'CRITICAL: XDC Node Alert'
    {% endif %}
    {% if alert_telegram_bot_token | length > 0 %}
    telegram_configs:
      - bot_token: '{{ alert_telegram_bot_token }}'
        chat_id: {{ alert_telegram_chat_id }}
        message: 'CRITICAL: {{ '{{' }} .GroupLabels.alertname {{ '}}' }} - {{ '{{' }} .Annotations.summary {{ '}}' }}'
    {% endif %}

  - name: 'warning'
    {% if alert_email_to | length > 0 %}
    email_configs:
      - to: '{{ alert_email_to }}'
        subject: 'WARNING: XDC Node Alert'
    {% endif %}
