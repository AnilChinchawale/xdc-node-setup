global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    monitor: 'xdc-monitor'
    node: '{{ inventory_hostname }}'

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:9093

rule_files:
  - /etc/prometheus/alerts/*.yml

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:9100']
        labels:
          instance: '{{ inventory_hostname }}'

  - job_name: 'xdc-node'
    metrics_path: /debug/metrics/prometheus
    static_configs:
      - targets: ['host.docker.internal:{{ rpc_port | default(8545) }}']
        labels:
          instance: '{{ inventory_hostname }}'
          client: '{{ client }}'
          role: '{{ node_role }}'
