# XDC Node Setup - Environment Variables
# Copy this file to .env and fill in your values

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# RPC Configuration
RPC_ADDR=127.0.0.1
RPC_PORT=8545

# RPC Rate Limiting (requests per minute per IP)
RPC_RATE_LIMIT=100

# TLS Configuration
TLS_ENABLED=false
TLS_CERT_PATH=/certs/server.crt
TLS_KEY_PATH=/certs/server.key

# Let's Encrypt (for production)
LETSENCRYPT_ENABLED=false
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_DOMAIN=node.example.com

# Node Configuration
INSTANCE_NAME=my-xdc-node
CONTACT_DETAILS=admin@example.com
NETWORK=mainnet
SYNC_MODE=full

# SkyNet (Optional)
SKYNET_API_KEY=
SKYNET_ENDPOINT=https://net.xdc.network
