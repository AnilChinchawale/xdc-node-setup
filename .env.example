# XDC Node Setup - Environment Variables
# Copy this file to .env and fill in your values

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_PASSWORD:-admin_change_me}
GRAFANA_PASSWORD=

# RPC Configuration
RPC_ADDR=127.0.0.1
RPC_PORT=8545

# Node Configuration
INSTANCE_NAME=my-xdc-node
CONTACT_DETAILS=admin@example.com
NETWORK=mainnet
SYNC_MODE=full

# SkyNet (Optional)
SKYNET_API_KEY=
SKYNET_ENDPOINT=https://net.xdc.network
