# XDC SkyOne Dashboard Environment Variables
# Copy to .env and configure for your environment

# XDC Node RPC Endpoint
RPC_URL=http://xdc-node:8545

# Dashboard Authentication (set both to enable basic auth)
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me-in-production

# Container name for diagnostics
CONTAINER_NAME=xdc-node

# Next.js port
PORT=3000

# Refresh interval in seconds
NEXT_PUBLIC_REFRESH_INTERVAL=10
